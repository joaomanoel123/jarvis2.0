# ════════════════════════════════════════════════════════════════════
#  JARVIS v2 — Environment Variables Reference
#  Copy to .env and fill in your values.  Never commit .env.
# ════════════════════════════════════════════════════════════════════

# ── HuggingFace LLM ─────────────────────────────────────────────────
# Friendly alias (see MODEL_REGISTRY in settings.py) or full HF model ID.
# CPU-safe options:  tinyllama | phi-2
# GPU options:       mistral-7b | llama-3 | phi-3-mini | deepseek-coder
LLM_MODEL_ID=tinyllama

# Required for gated models (Llama 3, Mistral-7B-v0.3).
# Generate at: https://huggingface.co/settings/tokens
HF_TOKEN=

# Device: auto (recommended) | cpu | cuda | cuda:0 | mps (Apple Silicon)
LLM_DEVICE=auto

# 4-bit NF4 quantisation — halves VRAM.  Requires bitsandbytes + GPU.
# Set to false for CPU-only deployments.
LLM_LOAD_IN_4BIT=false

# Token budget per response
LLM_MAX_NEW_TOKENS=1024

# Sampling temperature: 0.0 = deterministic, 1.0 = creative, max 2.0
LLM_TEMPERATURE=0.7

# Keep at 1 — raising this spawns multiple model copies and causes OOM
LLM_THREAD_WORKERS=1


# ── Tool sandbox ─────────────────────────────────────────────────────
# Comma-separated list of tools that agents are allowed to call.
# Remove a tool name to block it at runtime without code changes.
ALLOWED_TOOLS=web_search,run_python_code,file_reader,system_status

# Maximum seconds a tool call may run before being cancelled
TOOL_TIMEOUT_SECONDS=30

# Maximum bytes of tool output returned to the agent
TOOL_MAX_OUTPUT_BYTES=65536

# Thread workers for CPU-bound tool calls
TOOL_THREAD_WORKERS=4


# ── Memory / sessions ────────────────────────────────────────────────
# Idle session TTL in seconds (3600 = 1 hour)
SESSION_TTL_SECONDS=3600

# Rolling window of messages kept per session (oldest are evicted)
MAX_HISTORY_MESSAGES=40

# Short-term memory TTL in seconds (300 = 5 minutes)
SHORT_TERM_TTL=300


# ── Application ──────────────────────────────────────────────────────
APP_NAME=JARVIS
APP_VERSION=2.0.0

# Set to true to expose exception details in API error responses
DEBUG=false

# Comma-separated or JSON list of allowed CORS origins.
# Production: set to your exact frontend domain.
# Development: http://localhost:3000
ALLOWED_ORIGINS=["http://localhost:3000"]


# ── External APIs (optional integrations) ───────────────────────────
# Replace the DuckDuckGo web_search tool with SerpAPI:
# EXTERNAL_API_KEY=your_serpapi_key
# EXTERNAL_API_BASE_URL=https://serpapi.com/search
